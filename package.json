{
  "name": "@dschmidt/cdktf-internal-provider-google",
  "description": "A prebuilt provider for google, testing out an alternative code generation for cdktf",
  "repository": {
    "type": "git",
    "url": "https://github.com/hashicorp/cdktf-provider-google.git"
  },
  "scripts": {
    "build": "scripts/run-task build",
    "bump": "scripts/run-task bump",
    "clobber": "scripts/run-task clobber",
    "compat": "scripts/run-task compat",
    "compile": "jsii --silence-warnings=reserved-word",
    "docgen": "scripts/run-task docgen",
    "fetch": "scripts/run-task fetch",
    "package": "scripts/run-task package",
    "package-all": "scripts/run-task package-all",
    "package:dotnet": "scripts/run-task package:dotnet",
    "package:go": "scripts/run-task package:go",
    "package:java": "scripts/run-task package:java",
    "package:js": "scripts/run-task package:js",
    "package:python": "scripts/run-task package:python",
    "post-compile": "scripts/run-task post-compile",
    "post-upgrade": "scripts/run-task post-upgrade",
    "pre-compile": "scripts/run-task pre-compile",
    "release": "scripts/run-task release",
    "test": "jest --passWithNoTests",
    "unbump": "scripts/run-task unbump",
    "upgrade": "scripts/run-task upgrade",
    "watch": "scripts/run-task watch",
    "commit": "git add -A && git commit -am \"Update provider\" || echo \"No changes to commit\"",
    "should-release": "! git diff --exit-code v$(cat version.json | jq -r '.version') ./src ./package.json",
    "prebump": "yarn fetch && yarn compile && yarn run commit && yarn run should-release",
    "build-provider": "yarn fetch && yarn compile && yarn docgen"
  },
  "author": {
    "name": "HashiCorp",
    "url": "https://hashicorp.com",
    "organization": true
  },
  "devDependencies": {
    "@cdktf/provider-project": "^0.2.8",
    "@types/node": "^14",
    "cdktf": "^0.12.2",
    "cdktf-cli": "^0.12.2",
    "constructs": "^10.0.0",
    "dot-prop": "^5.2.0",
    "jsii": "^1.53.0",
    "jsii-diff": "^1.67.0",
    "jsii-docgen": "^7.0.82",
    "jsii-pacmak": "^1.67.0",
    "npm-check-updates": "^15",
    "standard-version": "^9",
    "typescript": "^4.8.3"
  },
  "peerDependencies": {
    "cdktf": "^0.12.2",
    "constructs": "^10.0.0"
  },
  "keywords": [],
  "engines": {
    "node": ">= 14.17.0"
  },
  "main": "lib/index.js",
  "license": "MPL-2.0",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0",
  "types": "lib/index.d.ts",
  "stability": "stable",
  "jsii": {
    "outdir": "dist",
    "targets": {
      "java": {
        "package": "com.hashicorp.dschmidt.providers.google",
        "maven": {
          "groupId": "com.hashicorp",
          "artifactId": "dschmidt-provider-google"
        }
      },
      "python": {
        "distName": "dschmidt-dschmidt-provider-google",
        "module": "dschmidt_dschmidt_provider_google"
      },
      "dotnet": {
        "namespace": "HashiCorp.Dschmidt.Providers.Google",
        "packageId": "HashiCorp.Dschmidt.Providers.Google"
      },
      "go": {
        "moduleName": "github.com/DanielMSchmidt/dschmidt-provider-google-go"
      }
    },
    "tsc": {
      "outDir": "lib",
      "rootDir": "src"
    }
  },
  "resolutions": {
    "@types/prettier": "2.6.0"
  }
}
